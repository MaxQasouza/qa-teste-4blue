{
  "name": "qa-play-sim-cypress-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Suíte de testes E2E com Cypress para o sistema qa-play-sim.lovable.app",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run --spec \"cypress/e2e/login.cy.js,cypress/e2e/criar-conta.cy.js,cypress/e2e/sucesso.cy.js\"",
    "cy:run:bugs": "cypress run --spec \"cypress/e2e/*.bugs.cy.js\"",
    "cy:run:all": "cypress run --spec \"cypress/e2e/**/*\""
  },
  "devDependencies": {
    "cypress": "^13.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
